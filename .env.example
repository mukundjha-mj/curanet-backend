# ===================================
# CuraNet Healthcare Platform - Environment Variables
# ===================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ===================================

# Node Environment
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/curanet

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-long-change-this-in-production
PASSWORD_PEPPER=your-password-pepper-for-additional-security

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Email Configuration (SMTP)
EMAIL_FROM=no-reply@curanet.in
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Email Configuration (Resend - Preferred)
# Replace re_xxxxxxxxx with your real Resend API key
RESEND_API_KEY=re_xxxxxxxxx

# Twilio Configuration (for SMS OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# AI Integration (Groq/LLM)
GROQ_API_KEY=your-groq-api-key

# Admin Bootstrap
# Token for creating first admin user (remove after setup)
ADMIN_BOOTSTRAP_TOKEN=your-secure-bootstrap-token

# Application Base URL
BASE_URL=http://localhost:3001

# File Upload Configuration
MAX_FILE_SIZE=52428800
# 50MB in bytes (50 * 1024 * 1024)
MAX_FILES_PER_REQUEST=10

# Logging Level (debug, info, warn, error)
LOG_LEVEL=debug

# ===================================
# Security / Runtime Configuration
# ===================================
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
STRICT_RATE_LIMIT_WINDOW_SECONDS=60
STRICT_RATE_LIMIT_MAX=5

JWT_ACCESS_TOKEN_EXPIRY_WEB=15m
JWT_ACCESS_TOKEN_EXPIRY_MOBILE=30d
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

PASSWORD_MIN_LENGTH=8
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_FAILED_ATTEMPTS=5

COOKIE_SAME_SITE=strict
COOKIE_SECURE=true

SELF_REPORTING_RATE_LIMIT=10
SELF_REPORTING_RATE_WINDOW_MINUTES=60

MAX_FILE_SIZE_BYTES=52428800
MAX_JSON_BODY_SIZE_MB=25

HSTS_MAX_AGE=31536000

MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_LOCKOUT_MINUTES=15

CONSENT_REQUEST_EXPIRY_HOURS=48
CONSENT_REQUEST_EXPIRY_HOURS_DEV=168
CONSENT_EXPIRY_DAYS=365
EMERGENCY_SHARE_EXPIRY_HOURS=24
EMERGENCY_SHARE_MAX_EXPIRY_SECONDS=86400
EMERGENCY_SHARE_DEFAULT_EXPIRY_SECONDS=3600
SESSION_TIMEOUT_MINUTES=60

# Application Performance Monitoring
# Options: none, newrelic, datadog, appinsights, prometheus
APM_PROVIDER=none
# APM_CONNECTION_STRING=your-apm-connection-string

# ===================================
# Production Recommendations:
# ===================================
# 1. Use strong, randomly generated secrets (min 32 characters)
# 2. Enable HTTPS and set secure cookies
# 3. Use environment-specific values
# 4. Store secrets in a vault (Azure Key Vault, AWS Secrets Manager, etc.)
# 5. Rotate secrets regularly
# 6. Remove ADMIN_BOOTSTRAP_TOKEN after initial setup
# ===================================
